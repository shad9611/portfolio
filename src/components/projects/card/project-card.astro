---
import { Icon } from "astro-icon/components";
import AppIcon from "../../../shared/AppIcon.astro";
import type { Project } from "../../../types/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;

// FIX typo + safety
const badges = [
  ...(project.technologies ?? []),
  ...(project.architectures ?? []),
];
---

<article
  class="group flex h-full flex-col rounded-2xl border border-zinc-200 bg-white/70 p-6 backdrop-blur-sm transition-all duration-300 hover:-translate-y-2 hover:border-orange-400/50 hover:shadow-xl dark:border-zinc-800 dark:bg-zinc-900/50"
>
  <!-- HEADER -->
  <div class="flex items-center justify-between">
    <h3 class="text-xl font-bold">
      {project.title}
    </h3>

    <span
      class="rounded-full border border-orange-500/20 bg-orange-500/10 px-3 py-1 text-xs font-semibold text-orange-500"
    >
      {project.status}
    </span>
  </div>

  <!-- DESCRIPTION -->
  <p class="mt-4 flex-1 text-zinc-600 dark:text-zinc-400">
    {project.description}
  </p>

  <!-- BADGES -->
  <div class="mt-5 flex flex-wrap gap-2">
    {
      badges.map((item) => {
        if (!item) return null;

        return (
          <span class="inline-flex items-center gap-2 rounded-full border border-zinc-200 bg-white/70 px-3 py-1.5 text-sm font-medium text-zinc-700 transition-all duration-300 hover:border-orange-400/40 hover:text-orange-500 dark:border-zinc-700 dark:bg-zinc-900/50 dark:text-zinc-300">
            {item.icon && <AppIcon name={item.icon} class="h-4 w-4" />}

            <span>{item.name}</span>
          </span>
        );
      })
    }
  </div>

  <!-- ACTIONS (FIX: estaba fuera del article) -->
  <div class="mt-6 flex gap-3">
    {
      project.githubUrl && (
        <a
          href={project.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-zinc-300 px-4 py-2 transition hover:border-orange-500 dark:border-zinc-700"
        >
          <Icon name="mdi:github" />
          Código
        </a>
      )
    }

    {
      project.demoUrl && (
        <a
          href={project.demoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-zinc-300 px-4 py-2 transition hover:border-orange-500 dark:border-zinc-700"
        >
          <Icon name="lucide:external-link" />
          Demo
        </a>
      )
    }
  </div>
</article>
