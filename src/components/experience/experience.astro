---
import { getExperiences } from "../../data/experiences-data";
import ExperienceCard from "./card/experience-card.astro";

const experiences = getExperiences();

const { t } = Astro.props;
---

<section class="mx-auto w-full max-w-5xl">
  <h2
    class="mb-12
      text-center
      text-4xl
      font-bold
      tracking-tight
      md:text-5xl"
  >
    {t.experience.title}
  </h2>

  <div class="relative space-y-6">
    {
      experiences.map((experience) => (
        <ExperienceCard experience={experience} t={t} />
      ))
    }
  </div>
</section>
