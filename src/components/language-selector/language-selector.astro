---
interface Props {
  code: string;
  label: string;
  lang: string;
}

const { code, label, lang } = Astro.props;
---

<a
  href={`${import.meta.env.BASE_URL}/${code}`}
  class:list={[
    `
      inline-flex items-center justify-center
      rounded-full
      border
      px-3 py-2
      text-sm font-semibold
      backdrop-blur-md

      transition-all duration-300
      hover:-translate-y-1
      hover:shadow-lg
    `,
    lang === code
      ? `
        border-orange-400/50
        bg-orange-500/10
        text-orange-500
        shadow-lg shadow-orange-500/10
      `
      : `
        border-zinc-300/60
        bg-white/60
        text-zinc-600

        hover:border-orange-400/50
        hover:text-orange-500

        dark:border-zinc-700/50
        dark:bg-white/5
        dark:text-zinc-400
      `,
  ]}
>
  {label}
</a>
