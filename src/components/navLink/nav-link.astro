---
interface Props {
  href: string;
  label: string;
}

const { href, label } = Astro.props;
---

<a
  href={href}
  class="inline-flex
    items-center
    rounded-full
    px-4
    py-2
    font-semibold
    text-zinc-700
    hover:bg-orange-100
    hover:text-orange-600
    hover:-translate-y-0.5
    dark:text-zinc-400
    dark:hover:bg-white/5
    dark:hover:text-white
    transition-all
    duration-300"
>
  {label}
</a>
