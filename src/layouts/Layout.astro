---
import { getAssetPath } from "../shared/utils/get-asset-path";
import "../styles/global.css";

interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
---

<html lang={lang} class="bg-white text-black dark:bg-zinc-950 dark:text-white">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <script is:inline>
      const theme = localStorage.getItem("theme");

      if (
        theme === "dark" ||
        (!theme && window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      }
    </script>

    <link rel="icon" type="image/svg+xml" href={getAssetPath("/favicon.svg")} />
    <link rel="icon" href={getAssetPath("/favicon.ico")} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <meta name="generator" content={Astro.generator} />

    <title>Portfolio</title>
  </head>

  <body class="min-h-screen">
    <div class="fixed inset-0 -z-10 overflow-hidden">
      <!-- Light -->
      <div
        class="absolute left-1/4 top-20 h-96 w-96 rounded-full bg-orange-300/20 blur-3xl dark:hidden"
      >
      </div>

      <div
        class="absolute right-1/4 top-52 h-96 w-96 rounded-full bg-sky-300/20 blur-3xl dark:hidden"
      >
      </div>

      <div
        class="absolute bottom-0 left-1/2 h-96 w-96 -translate-x-1/2 rounded-full bg-violet-300/15 blur-3xl dark:hidden"
      >
      </div>

      <!-- Dark -->
      <div
        class="hidden dark:block absolute left-1/4 top-24 h-96 w-96 rounded-full bg-orange-500/15 blur-3xl"
      >
      </div>

      <div
        class="hidden dark:block absolute right-1/4 top-40 h-96 w-96 rounded-full bg-pink-500/10 blur-3xl"
      >
      </div>

      <div
        class="hidden dark:block absolute bottom-0 left-1/2 h-96 w-96 -translate-x-1/2 rounded-full bg-violet-500/15 blur-3xl"
      >
      </div>
    </div>

    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }
</style>
